{
  "name": "@better-translate/vite",
  "version": "0.1.0",
  "description": "Vite plugin for extracting, generating, and validating Better Translate locale artifacts.",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@better-translate/core": "workspace:*",
    "oxc-parser": "0.123.0"
  },
  "devDependencies": {
    "@better-translate/tsconfig": "workspace:*",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "vite": ">=8"
  }
}
