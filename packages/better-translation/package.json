{
  "name": "better-translation",
  "version": "0.1.2",
  "description": "Vite plugin and runtime helpers for Better Translation.",
  "repository": {
    "type": "git",
    "url": "https://github.com/NoQuarterTeam/better-translation.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./vite": {
      "import": "./dist/vite.mjs",
      "types": "./dist/vite.d.mts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "types": "./dist/react.d.mts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "types": "./dist/server.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "bun run build"
  },
  "dependencies": {
    "oxc-parser": "0.123.0"
  },
  "devDependencies": {
    "@better-translation/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19",
    "vite": ">=8"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
